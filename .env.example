# Isaac — Beispiel-Konfiguration (kopiere nach .env)
# In GitHub Codespaces: GROQ_API_KEY als User/Repo-Secret setzen, nicht hier eintragen.

ISAAC_OWNER=Steffen

# Provider: groq (empfohlen in Codespaces), openrouter, ollama (nur lokal)
ACTIVE_PROVIDER=groq

# Groq — kostenloser Tier: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter (primäres Multi-Model-Gateway)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# Ensemble: mehrere Modelle vergleichen/kombinieren (ensemble: …)
ISAAC_ENSEMBLE=1
ISAAC_ENSEMBLE_FREE_ONLY=1
ISAAC_ENSEMBLE_N=3
ISAAC_ENSEMBLE_STAGGER_MS=800
ISAAC_ENSEMBLE_JUDGE=1
# Always-on nur bei schweren CHAT-Fragen (nicht Tools/Greetings)
ISAAC_ENSEMBLE_AUTO=1
ISAAC_ENSEMBLE_AUTO_MIN_WORDS=22
# OPENROUTER_ENSEMBLE_MODELS=meta-llama/llama-3.2-3b-instruct:free,google/gemma-2-9b-it:free

# Ollama (nur lokal / Termux — in Codespaces nicht verfügbar)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=300

# Lokales OpenAI-kompatibles Backend (LM Studio / vLLM / llama.cpp server / LocalAI)
# Kernel steuert über Relay: ACTIVE_PROVIDER=local
# ACTIVE_PROVIDER=local
LOCAL_LLM_ENABLED=1
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1/chat/completions
LOCAL_LLM_MODEL=local-model
# LOCAL_LLM_API_KEY=          # optional; die meisten lokalen Server brauchen keinen Key
# LOCAL_LLM_TIMEOUT=180

# Monitor / Dashboard
MONITOR_PORT=8765
DASHBOARD_PORT=8766
MONITOR_HTTP_PORT=8766

# Chroma/onnx in CI/Codespaces deaktivieren
ISAAC_DISABLE_VECTOR_MEMORY=1

# Privilege-Modus für lokale Geräte:
# - "user"   : Standard-Sicherheitsmode (Standard)
# - "admin"  : Vollständiger Zugriff wie Owner, keine Gating-Fragen (für Android/lokale Geräte)
ISAAC_PRIVILEGE_MODE=user